#!/usr/bin/env python3
import csv
import math
import os
import sys
from dataclasses import dataclass
from statistics import mean
from typing import TextIO

TP = "tp"
NO_TP = "no_tp"
TOTAL = "total"
RUN_KINDS = (NO_TP, TP)
NAMES = {
    TP: "With Teleport",
    NO_TP: "Without Teleport",
}
PERCENTILES = (25, 50, 75, 95, 99)


@dataclass(frozen=True)
class ReportStats:
    title: str
    vals: list[float]
    tasks: set[str]
    errors: int
    error_tasks: set[str]
    min: float
    avg: float
    max: float
    percentiles: dict[int, float]

def percentile(vals: list[float], p: int) -> float:
    ys = sorted(vals)
    i = math.ceil(len(ys) * p / 100) - 1
    return ys[max(0, min(i, len(ys) - 1))]

def hist(vals: list[float], bins: int = 20, width: int = 50) -> list[str]:
    lo, hi = min(vals), max(vals)

    if lo == hi:
        return [f"{lo:.3f}s | {'#' * width} {len(vals)}"]

    step = (hi - lo) / bins
    counts = [0] * bins

    for x in vals:
        counts[min(int((x - lo) / step), bins - 1)] += 1

    max_count = max(counts) or 1
    lines = []

    for i, n in enumerate(counts):
        a = lo + step * i
        b = a + step
        bar = "#" * round(n * width / max_count)
        lines.append(f"{a:10.3f}s - {b:10.3f}s | {bar} {n}")

    return lines

def calculate_stats(title: str,
                    vals: list[float],
                    tasks: set[str],
                    errors: int,
                    error_tasks: set[str]) -> ReportStats | None:
    if not vals:
        return None

    return ReportStats(
        title=title,
        vals=vals,
        tasks=tasks,
        errors=errors,
        error_tasks=error_tasks,
        min=min(vals),
        avg=mean(vals),
        max=max(vals),
        percentiles={p: percentile(vals, p) for p in PERCENTILES},
    )


def report(title: str, stats: ReportStats | None, other: ReportStats | None) -> None:
    if stats is None:
        print(f"\n{title}: no successful runs :(")
        return

    def delta_str(value: float, other_value: float | None) -> str:
        if other_value is None:
            return ""
        if other_value == 0:
            return " (n/a)"
        delta = ((value - other_value) / other_value) * 100
        sign = "+" if delta >= 0 else ""
        return f" ({sign}{delta:.1f}%)"

    print(f"""
-= {stats.title} =-
  runs - total:{len(stats.vals)}, task:{len(stats.tasks)}, total errors:{stats.errors}, tasks with errors:{len(stats.error_tasks)}
timing - min:{stats.min:.3f}s{delta_str(stats.min, None if other is None else other.min)}, avg:{stats.avg:.3f}s{delta_str(stats.avg, None if other is None else other.avg)}, max:{stats.max:.3f}s{delta_str(stats.max, None if other is None else other.max)}
""")
    for p in PERCENTILES:
        other_p = None if other is None else other.percentiles[p]
        print(f"p{p:<2}:   {stats.percentiles[p]:.3f}s{delta_str(stats.percentiles[p], other_p)}")

    if os.getenv('HIST'):
        print(f"\n{"\n".join(hist(stats.vals))}")

def read_results(path: str) -> tuple[
    dict[str, list[float]],
    set[str],
    dict[str, int],
    dict[str, set[str]],
]:
    runs: dict[str, list[float]] = {TP: [], NO_TP: []}
    tasks: set[str] = set()
    errors: dict[str, int] = {TP: 0, NO_TP: 0, TOTAL: 0}
    error_tasks: dict[str, set[str]] = {TP: set(), NO_TP: set(), TOTAL: set()}
    with open(path, newline="") as f:
        rows: csv.DictReader[TextIO] = csv.DictReader(f, delimiter="\t")

        for row in rows:
            task = row["#task"]

            for kind in RUN_KINDS:
                code = int(row[f"exit_code_{kind}"])
                tasks.add(task)

                if code:
                    errors[kind] += 1
                    errors[TOTAL] += 1
                    error_tasks[kind].add(task)
                    error_tasks[TOTAL].add(task)
                    continue

                start = int(row[f"start_{kind}"])
                end = int(row[f"end_{kind}"])
                runs[kind].append((end - start) / 1_000_000_000)
    return runs, tasks, errors, error_tasks

def main() -> None:
    if len(sys.argv) != 2:
        raise SystemExit(f"usage: {sys.argv[0]} results.tsv")
    runs, tasks, errors, error_tasks = read_results(sys.argv[1])
    stats = {
        kind: calculate_stats(NAMES[kind], runs[kind], tasks, errors[kind], error_tasks[kind])
        for kind in RUN_KINDS
    }
    for kind in RUN_KINDS:
        other_kind = TP if kind == NO_TP else NO_TP
        report(NAMES[kind], stats[kind], stats[other_kind])

if __name__ == "__main__":
    main()
