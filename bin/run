#!/bin/bash
set -euo pipefail
declare -r MY_D="$(readlink -f "$(dirname "${BASH_SOURCE}")")"
. "${MY_D}/include.sh"

declare CMD="upgrade --install"

DEBUG_FLAG=""
OVERWRITE="${OVERWRITE:-}"
if debug; then
  CMD="template"
  DEBUG_FLAG="--debug"
fi

if ! force; then 
  if have_saved_results; then
    msg "Saved results found, printing report..."
    report_saved_results
    exit "${EXIT_COMPLETE}"
  fi
  debug && msg "checking if complete..."
  if complete; then
    msg "Job run and done, fetching results..."
    "${ROOT_D}/bin/get-results" "${@}"
    exit "${EXIT_COMPLETE}"
  fi
  (DEBUG=t run_kubectl get "job/${K8S_JOB_NAME}" || true)
  (DEBUG=t run_kubectl get pods -l "${K8S_RUNNER_LABELS}" || true)
  debug && msg "not complete, checking if running..."
  if running; then
    msg "Job still running"
    exit "${EXIT_RUNNING}"
  fi
  debug && msg "not running or complete, checking if failed..."
  if failed; then
    msg "Job failed. Run with envvar FORCE=true to run it again."
    exit "${EXIT_FAILED}"
  fi
else
  debug && msg "Force enabled, skipped checking for existing runs"
fi

# export because we use them both here and in apply.sh
export TOKEN
export DEBUG
export OVERWRITE
BOT="${NAME}-bot" \
ROLE="${NAME}" \
K8S_GROUP="${GROUP}" \
K8S_NAMESPACE="${NAMESPACE}" \
K8S_SA="${RELEASE}" \
"${ROOT_D}/teleport/apply.sh" "${CONTEXT}" \
|| die "Failed to apply teleport objects"

if [[ -e "${RESULTS_TSV}" || -e "${STATUS_YAML}" ]]; then
  msg "Archiving old results"
  arc_ts="$(date +%s)"
  [[ -e "${RESULTS_TSV}" ]] \
    && (set -x; mv "${RESULTS_TSV}" "${RESULTS_TSV}.archived_at_${arc_ts}") \
    || die "Failed to archive old results"
  [[ -e "${STATUS_YAML}" ]] \
    && (set -x; mv "${STATUS_YAML}" "${STATUS_YAML}.archived_at_${arc_ts}") \
    || die "Failed to archive old results"
fi

if started; then
  # This let's us rerun without reinstalling the helm chart
  msg "Deleting old jobs"
  run_kubectl delete "job/${K8S_JOB_NAME}" --ignore-not-found \
    || die "Failed to clean up old jobs"
fi

msg "Ensuring helm deps"
helm dependency build >&2 . \
  || die "Failed to build deps"

msg "Installing chart"
(set -x; helm ${CMD} \
  "${RELEASE}" "${ROOT_D}" \
  --kube-context "${CONTEXT}" \
  --namespace "${NAMESPACE}" \
  --set group="${GROUP}" \
  --set tbot.token="${TOKEN}" \
  -f "${JOB_YAML}" \
  -f "${CLUSTER_YAML}" \
  ${DEBUG_FLAG}
  ) \
  || die "Failed to helm"

exit "${EXIT_STARTED}"
