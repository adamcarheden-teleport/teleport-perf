#!/bin/bash
set -euo pipefail
declare -r MY_D="$(readlink -f "$(dirname "${BASH_SOURCE}")")"
declare -r ROOT_D="$(readlink -f "${MY_D}/..")"
declare -r OUT_D="${OUT_D:-${ROOT_D}/test-config}"
declare -r ITERATIONS="${ITERATIONS:-50}"
declare -r REPLICAS_LIST="${REPLICAS_LIST:-1 5 10}"
declare -r STREAM_MODES="${STREAM_MODES:-txrx}"
declare -r DATA_SIZES="${DATA_SIZES:-1mb:1048576}"
declare -r BLOCK_SIZES="${BLOCK_SIZES:-64k:64K}"
declare -r DATA_SOURCES="${DATA_SOURCES:-zero}"

mkdir -p "${OUT_D}"

block_bytes() {
  local size
  size="$(printf "%s" "${1}" | tr '[:lower:]' '[:upper:]')"
  local re='^([0-9]+)([KMG])$'
  local n unit
  [[ "${size}" =~ ${re} ]] || {
    printf >&2 "Unsupported block size '%s'\n" "${1}"
    exit 1
  }
  n="${BASH_REMATCH[1]}"
  unit="${BASH_REMATCH[2]}"
  case "${unit}" in
    K) printf "%d\n" "$(( n * 1024 ))" ;;
    M) printf "%d\n" "$(( n * 1024 * 1024 ))" ;;
    G) printf "%d\n" "$(( n * 1024 * 1024 * 1024 ))" ;;
  esac
}

count_for() {
  local total_bytes="${1}"
  local block_size="${2}"
  local bytes_per_block
  bytes_per_block="$(block_bytes "${block_size}")"

  if (( total_bytes < bytes_per_block )); then
    return 1
  fi

  if (( total_bytes % bytes_per_block != 0 )); then
    return 1
  fi

  printf "%d\n" "$(( total_bytes / bytes_per_block ))"
}

output_file() {
  local replicas="${1}"
  local iterations="${2}"
  shift 2
  local components=("$@")
  components+=("r${replicas}" "x${iterations}")
  local IFS='-'
  printf "%s/%s.yaml\n" "${OUT_D}" "${components[*]}"
}

for replicas in ${REPLICAS_LIST}; do
  cat > "$(output_file "${replicas}" "${ITERATIONS}" ls)" <<EOF
---
iterations: ${ITERATIONS}
replicas: ${replicas}
type: "ls"
command: ""
EOF

  cat > "$(output_file "${replicas}" "${ITERATIONS}" exec latency)" <<EOF
---
iterations: ${ITERATIONS}
replicas: ${replicas}
type: "exec"
command: "echo hello"
EOF

  for source in ${DATA_SOURCES}; do
    infile="/dev/${source}"
    for size_spec in ${DATA_SIZES}; do
      IFS=: read -r size_name total_bytes <<< "${size_spec}"
      [[ -n "${size_name}" && -n "${total_bytes}" ]] || {
        printf >&2 "Invalid data size spec '%s'\n" "${size_spec}"
        exit 1
      }
      for block_spec in ${BLOCK_SIZES}; do
        IFS=: read -r block_name block_size <<< "${block_spec}"
        [[ -n "${block_name}" && -n "${block_size}" ]] || {
          printf >&2 "Invalid block size spec '%s'\n" "${block_spec}"
          exit 1
        }
        count="$(count_for "${total_bytes}" "${block_size}")" || continue

        for stream_mode in ${STREAM_MODES}; do
          case "${stream_mode}" in
            tx)
              cat > "$(output_file "${replicas}" "${ITERATIONS}" tx "${source}" "${size_name}" "${block_name}")" <<EOF
---
iterations: ${ITERATIONS}
replicas: ${replicas}
type: "exec"
command: "true"
input:
  count: ${count}
  block_size: ${block_size}
  file: "${infile}"
EOF
              ;;
            rx)
              cat > "$(output_file "${replicas}" "${ITERATIONS}" rx "${source}" "${size_name}" "${block_name}")" <<EOF
---
iterations: ${ITERATIONS}
replicas: ${replicas}
type: "exec"
command: "dd if=${infile} bs=${block_size} count=${count} status=none"
EOF
              ;;
            txrx)
              cat > "$(output_file "${replicas}" "${ITERATIONS}" txrx "${source}" "${size_name}" "${block_name}")" <<EOF
---
iterations: ${ITERATIONS}
replicas: ${replicas}
type: "exec"
command: "cat"
input:
  count: ${count}
  block_size: ${block_size}
  file: "${infile}"
EOF
              ;;
            *)
              printf >&2 "Unsupported STREAM_MODES entry '%s'\n" "${stream_mode}"
              exit 1
              ;;
          esac
        done
      done
    done
  done
done
