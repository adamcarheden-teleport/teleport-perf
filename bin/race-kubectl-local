#!/usr/bin/env bash
set -euo pipefail

declare -r DEBUG="${DEBUG:-}"
debug() {
  [[ -n "${DEBUG}" && "$(echo "${DEBUG}" | tr 'a-z' 'A-Z')" != "FALSE" ]]
}

msg() {
  printf >&2 "%s\n" "${*}"
}

die() {
  msg "ERROR: ${*}"
  exit 1
}

is_true() {
  local value
  value="$(printf '%s' "${1:-}" | tr '[:upper:]' '[:lower:]')"
  case "${value}" in
    ""|0|false|no|off) return 1 ;;
    *) return 0 ;;
  esac
}

declare SELF_SOURCE="${RERUN_SCRIPT_PATH:-}"
if [[ -z "${SELF_SOURCE}" ]]; then
  SELF_SOURCE="${BASH_SOURCE:-$0}"
fi
declare -r ROOT_D="${RERUN_ROOT_D:-$(readlink -f "$(dirname "${SELF_SOURCE}")/..")}"
declare -r ARG1="${1:-${RERUN_ARG1:-local}}"
declare CONFIG_TEST_NAME=""
if [[ "${ARG1}" == config/* ]]; then
  declare -r CONFIG_FILE="${ROOT_D}/${ARG1}"
  [[ -r "${CONFIG_FILE}" ]] \
    || die "Config file '${CONFIG_FILE}' not found"
  # shellcheck source=/dev/null
  . "${CONFIG_FILE}"
  CONFIG_TEST_NAME="$(basename "${ARG1}")"
  [[ "${CONFIG_TEST_NAME}" == local.* ]] \
    || die "Config file name '${CONFIG_TEST_NAME}' must start with 'local.'"
fi

declare -r FORCE="${FORCE:-}"
declare -r NAMESPACE="${NAMESPACE:-teleport-performance}"
declare -r POD="${POD:-tperf-target}"
declare -r IMAGE="${IMAGE:-busybox:latest}"
declare -r TP_CLUSTER="${TP_CLUSTER:-teleport.example.com}"
declare -r CONTEXT_NO_TP="${CONTEXT_NO_TP:-my-teleport-cluster}"
declare -r CONTEXT_TP="${CONTEXT_TP:-${TP_CLUSTER}-${CONTEXT_NO_TP}}"
declare -r USE_TSH_PROXY="${USE_TSH_PROXY:-true}"
declare -r ITERATIONS="${ITERATIONS:-30}"
declare -r CMD="${CMD:-echo hello}"
declare -r TX_COUNT="${TX_COUNT:-0}"
declare -r TX_BLOCK_SIZE="${TX_BLOCK_SIZE:-0}"
declare -r TX_INFILE="${TX_INFILE:-/dev/zero}"
declare -r MAX_READY_WAIT="${MAX_READY_WAIT:-5m}"
declare -r DEFAULT_KUBECONFIG="${ORIGINAL_KUBECONFIG:-${KUBECONFIG:-${HOME}/.kube/config}}"
declare -r TP_CONTEXT_PREFIX="${TP_CLUSTER}-"
[[ "${CONTEXT_TP}" == "${TP_CONTEXT_PREFIX}"* ]] \
  || die "CONTEXT_TP '${CONTEXT_TP}' must start with '${TP_CONTEXT_PREFIX}' so the Teleport kube cluster name can be derived"
declare -r K8S_CLUSTER="${CONTEXT_TP#${TP_CONTEXT_PREFIX}}"
[[ -n "${K8S_CLUSTER}" ]] \
  || die "Failed to derive Teleport kube cluster name from CONTEXT_TP '${CONTEXT_TP}'"

tsh_proxy_kubectl() {
  (set -x; kubectl --kubeconfig="${KUBECONFIG}" "$@")
}

PROXY_CONTEXT=""
verify_tsh_proxy() {
  local cl k8s_cl ctx_expr proxy_expr ext_expr

  [[ -n "${KUBECONFIG:-}" ]] \
    || die "KUBECONFIG not set. tsh proxy should set it when USE_TSH_PROXY is enabled."

  PROXY_CONTEXT="$(tsh_proxy_kubectl config current-context)" \
    || die "Failed to read current context from tsh proxy kubeconfig '${KUBECONFIG}'"
  ctx_expr=".contexts[] | select(.name == \"${PROXY_CONTEXT}\") | .context.cluster"
  cl="$(tsh_proxy_kubectl config view | yq "${ctx_expr}")" \
    || die "Failed to resolve cluster for tsh proxy context '${PROXY_CONTEXT}'"

  proxy_expr=".clusters[] | select(.name == \"${cl}\") | .cluster.proxy-url"
  tsh_proxy_kubectl config view \
    | yq "${proxy_expr}" \
    | grep 'http://127\.0\.0\.1:' >/dev/null \
    || die "Teleport kubeconfig '${KUBECONFIG}' is not using a localhost tsh proxy"

  ext_expr=".clusters[] | select(.name == \"${cl}\") | .cluster.extensions[] | select(.name == \"teleport.kube.name\") | .extension"
  k8s_cl="$(tsh_proxy_kubectl config view | yq "${ext_expr}")" \
    || die "Failed to resolve teleport.kube.name for tsh proxy cluster '${cl}'"
  [[ "${K8S_CLUSTER}" == "${k8s_cl}" ]] \
    || die "Wrong Teleport kube cluster through tsh proxy: expected '${K8S_CLUSTER}', got '${k8s_cl}'"

  msg "SUCCESS: Connected to '${k8s_cl}' through tsh proxy"
}

if is_true "${USE_TSH_PROXY}"; then
  if [[ -z "${RERUN_WITH_TSH_PROXY:-}" ]]; then
    export ORIGINAL_KUBECONFIG="${DEFAULT_KUBECONFIG}"
    export RERUN_ARG1="${ARG1}"
    export RERUN_ROOT_D="${ROOT_D}"
    export RERUN_SCRIPT_PATH="$(readlink -f "${SELF_SOURCE}")"
    export RERUN_WITH_TSH_PROXY=true
    exec tsh --proxy="${TP_CLUSTER}" proxy kube "${K8S_CLUSTER}" --exec < "${RERUN_SCRIPT_PATH}"
  fi
  verify_tsh_proxy
  declare -r TP_KUBECONFIG="${KUBECONFIG}"
  declare -r TP_CONTEXT="${PROXY_CONTEXT}"
  declare -r TP_MODE_DESC="tsh proxy kubeconfig '${TP_KUBECONFIG}' context '${TP_CONTEXT}'"
else
  declare -r TP_KUBECONFIG="${DEFAULT_KUBECONFIG}"
  declare -r TP_CONTEXT="${CONTEXT_TP}"
  declare -r TP_MODE_DESC="kubectl kubeconfig '${TP_KUBECONFIG}' context '${TP_CONTEXT}'"
fi
declare -r NO_TP_KUBECONFIG="${DEFAULT_KUBECONFIG}"
declare -r NO_TP_CONTEXT="${CONTEXT_NO_TP}"

declare -r RESULTS_D="${ROOT_D}/results"
if [[ -n "${CONFIG_TEST_NAME}" ]]; then
  declare -r FULL_TEST_NAME="${CONFIG_TEST_NAME}"
else
  declare -r FULL_TEST_NAME="local.${CONTEXT_NO_TP}.${ARG1}-x${ITERATIONS}"
fi
declare -r TEST_D="${RESULTS_D}/${FULL_TEST_NAME}"
declare -r RESULTS_TSV="${TEST_D}/${FULL_TEST_NAME}.tsv"

kubectl_run() {
  local kubeconfig="${1:-}"
  local context="${2:-}"
  shift 2
  [[ -n "${kubeconfig}" ]] || die "kubectl_run requires a kubeconfig"
  [[ -n "${context}" ]] || die "kubectl_run requires a context"
  kubectl --kubeconfig "${kubeconfig}" --context "${context}" --namespace "${NAMESPACE}" "$@"
}

mkdir -p "${TEST_D}" || die "Failed to create test directory '${TEST_D}'"
[[ -z "${FORCE}" && -e "${RESULTS_TSV}" ]] \
  && die "Results file '${RESULTS_TSV}' already exists. Use FORCE=1 to overwrite."

msg "Applying pod/${POD} in namespace ${NAMESPACE}"
if ! kubectl_run "${NO_TP_KUBECONFIG}" "${NO_TP_CONTEXT}" apply -f - <<EOF
apiVersion: v1
kind: Pod
metadata:
  name: ${POD}
  namespace: ${NAMESPACE}
  labels:
    app.kubernetes.io/name: tperf-local
spec:
  restartPolicy: Never
  containers:
  - name: target
    image: ${IMAGE}
    command:
    - /bin/sh
    - -c
    - |
      trap 'exit 0' TERM INT
      while true; do
        sleep 10 &
        wait \$!
      done
EOF
then
  die "Failed to apply pod/${POD} in namespace ${NAMESPACE}"
fi

kubectl_run "${NO_TP_KUBECONFIG}" "${NO_TP_CONTEXT}" wait "pod/${POD}" \
  --for=condition=ready \
  --timeout="${MAX_READY_WAIT}" \
  || die "Target pod '${POD}' was not ready after '${MAX_READY_WAIT}'"

kubectl_run "${TP_KUBECONFIG}" "${TP_CONTEXT}" get "pod/${POD}" >/dev/null \
  || die "Failed to query pod/${POD} through Teleport using ${TP_MODE_DESC}"

run_test() {
  local kubeconfig="${1:-}"
  local context="${2:-}"
  [[ -n "${kubeconfig}" ]] || die "run_test requires a kubeconfig"
  [[ -n "${context}" ]] || die "run_test requires a context"

  local read_cmd='printf ""'
  local remote_cmd=(sh -c "${CMD} && cat >/dev/null")
  local kubectl_args=(exec -i "${POD}" -- "${remote_cmd[@]}")

  [[ "${TX_COUNT}" -gt 0 && "${TX_BLOCK_SIZE}" != "0" ]] \
    && read_cmd="dd if=${TX_INFILE} bs=${TX_BLOCK_SIZE} count=${TX_COUNT}"

  local before
  before="$(date +%s%N)"

  (
    set +e
    set -o pipefail
    ${read_cmd} \
      | (set -x; kubectl --kubeconfig "${kubeconfig}" --context "${context}" --namespace "${NAMESPACE}" "${kubectl_args[@]}") \
      | cat >/dev/null
  )
  local ret="${?}"

  local after
  after="$(date +%s%N)"
  printf "%d\t%d\t%d\n" "${before}" "${after}" "${ret}"
}

printf "#%s\t%s\t%s\t%s\t%s\t%s\t%s\t%s\n" \
  "task" \
  iter \
  "start_no_tp" \
  "end_no_tp" \
  "exit_code_no_tp" \
  "start_tp" \
  "end_tp" \
  "exit_code_tp" \
  | tee "${RESULTS_TSV}" \
  || die "Failed to print header"

for i in $(seq 1 "${ITERATIONS}"); do
  msg "Running iteration ${i} of ${ITERATIONS}"

  x_results="$(run_test "${NO_TP_KUBECONFIG}" "${NO_TP_CONTEXT}")" \
    || die "Failed to run iteration '${i}' without Teleport"
  IFS=$'\t' read -r x_start x_end x_ret <<< "${x_results}"

  t_results="$(run_test "${TP_KUBECONFIG}" "${TP_CONTEXT}")" \
    || die "Failed to run iteration '${i}' with Teleport"
  IFS=$'\t' read -r t_start t_end t_ret <<< "${t_results}"

  printf "%d\t%d\t%d\t%d\t%d\t%d\t%d\t%d\n" \
    0 "${i}" \
    "${x_start}" "${x_end}" "${x_ret}" \
    "${t_start}" "${t_end}" "${t_ret}" \
    | tee -a "${RESULTS_TSV}" \
    || die "Failed to print iteration '${i}'"
done

msg "Benchmark run complete, output at '${RESULTS_TSV}'"
