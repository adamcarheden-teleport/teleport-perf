#!/bin/bash
set -euo pipefail
declare -r MY_D="$(readlink -f "$(dirname "${BASH_SOURCE}")")"
declare -r ROOT_D="$(readlink -f "${MY_D}/..")"
declare -r CONFIG_D="${CONFIG_D:-${ROOT_D}/config}"
declare -r POLL_SECS="${POLL_SECS:-15}"
declare -r STOP_ON_FAILURE="${STOP_ON_FAILURE:-}"

usage() {
  printf >&2 "Usage: %s <cluster-config file>\n" "$(basename "${BASH_SOURCE}")"
  exit 1
}

[[ "${#}" -eq 1 ]] || usage

cluster_file="${1}"
[[ -f "${cluster_file}" ]] || {
  printf >&2 "Cluster config '%s' not found\n" "${1}"
  exit 1
}

cluster_name="$(basename "${cluster_file}")"
cluster_name="${cluster_name%.yaml}"

cleanup() {
  local config_file="${1}"
  "${ROOT_D}/bin/cleanup" "${config_file#${ROOT_D}/}" || {
    printf >&2 "Cleanup failed for '%s'\n" "${config_file#${ROOT_D}/}"
    exit 124
  }
}

for config_file in "${CONFIG_D}/${cluster_name}".*; do
  [[ -e "${config_file}" ]] || continue
  while true; do
    set +e
    "${ROOT_D}/bin/run" "${config_file#${ROOT_D}/}"
    ret="${?}"
    set -e

    case "${ret}" in
      0)
        # complete
        cleanup "${config_file}"
        break
        ;;
      1|2|3)
        # started this run or still in progress
        sleep "${POLL_SECS}"
        ;;
      125)
        # failed
        if [[ -n "${STOP_ON_FAILURE}" && "$(echo "${STOP_ON_FAILURE}" | tr 'a-z' 'A-Z')" != "FALSE" ]]; then
          echo >&2 "test case '${config_file}' failed and STOP_ON_FAILURE set, exiting..."
          exit "${ret}"
        fi
        cleanup "${config_file}"
        break
        ;;
      124)
        # die / hard failure
        if [[ -n "${STOP_ON_FAILURE}" && "$(echo "${STOP_ON_FAILURE}" | tr 'a-z' 'A-Z')" != "FALSE" ]]; then
          echo >&2 "test case '${config_file}' hit hard failure and STOP_ON_FAILURE set, exiting..."
          exit "${ret}"
        fi
        cleanup "${config_file}"
        break
        ;;
      *)
        printf >&2 "Unknown exit code from bin/run for '%s': %s\n" "${config_file#${ROOT_D}/}" "${ret}"
        exit "${ret}"
        ;;
    esac
  done
done
