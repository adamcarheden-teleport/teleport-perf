#!/usr/bin/env python3
import csv
import math
import os
import sys
from statistics import mean
from typing import TextIO

TP = "tp"
NO_TP = "no_tp"
TOTAL = "total"
RUN_KINDS = (NO_TP, TP)
NAMES = {
    TP: "With Teleport",
    NO_TP: "Without Teleport",
}

def percentile(vals: list[float], p: int) -> float:
    ys = sorted(vals)
    i = math.ceil(len(ys) * p / 100) - 1
    return ys[max(0, min(i, len(ys) - 1))]

def hist(vals: list[float], bins: int = 20, width: int = 50) -> list[str]:
    lo, hi = min(vals), max(vals)

    if lo == hi:
        return [f"{lo:.3f}s | {'#' * width} {len(vals)}"]

    step = (hi - lo) / bins
    counts = [0] * bins

    for x in vals:
        counts[min(int((x - lo) / step), bins - 1)] += 1

    max_count = max(counts) or 1
    lines = []

    for i, n in enumerate(counts):
        a = lo + step * i
        b = a + step
        bar = "#" * round(n * width / max_count)
        lines.append(f"{a:10.3f}s - {b:10.3f}s | {bar} {n}")

    return lines

def report(title: str,
           vals: list[float],
           tasks: set[str],
           errors: int,
           error_tasks: set[str]) -> None:
    if not vals:
        print(f"\n{title}: no successful runs :(")
        return
    
    print(f"""
-= {title} =-
  runs - total:{len(vals)}, task:{len(tasks)}, total errors:{errors}, tasks with errors:{len(error_tasks)}
timing - min:{min(vals):.3f}s, avg:{mean(vals):.3f}s, max:{max(vals):.3f}s
""")
    for p in (25, 50, 74, 95, 99):
        print(f"p{p:<2}:   {percentile(vals, p):.3f}s")

    if os.getenv('HIST'):
        print(f"\n{"\n".join(hist(vals))}")

def read_results(path: str) -> tuple[
    dict[str, list[float]],
    set[str],
    dict[str, int],
    dict[str, set[str]],
]:
    runs: dict[str, list[float]] = {TP: [], NO_TP: []}
    tasks: set[str] = set()
    errors: dict[str, int] = {TP: 0, NO_TP: 0, TOTAL: 0}
    error_tasks: dict[str, set[str]] = {TP: set(), NO_TP: set(), TOTAL: set()}
    with open(path, newline="") as f:
        rows: csv.DictReader[TextIO] = csv.DictReader(f, delimiter="\t")

        for row in rows:
            task = row["#task"]

            for kind in RUN_KINDS:
                code = int(row[f"exit_code_{kind}"])
                tasks.add(task)

                if code:
                    errors[kind] += 1
                    errors[TOTAL] += 1
                    error_tasks[kind].add(task)
                    error_tasks[TOTAL].add(task)
                    continue

                start = int(row[f"start_{kind}"])
                end = int(row[f"end_{kind}"])
                runs[kind].append((end - start) / 1_000_000_000)
    return runs, tasks, errors, error_tasks

def main() -> None:
    if len(sys.argv) != 2:
        raise SystemExit(f"usage: {sys.argv[0]} results.tsv")
    runs, tasks, errors, error_tasks = read_results(sys.argv[1])
    for kind in RUN_KINDS:
        report(NAMES[kind], runs[kind], tasks, errors[kind], error_tasks[kind])

if __name__ == "__main__":
    main()