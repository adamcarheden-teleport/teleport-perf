#!/bin/bash
set -euo pipefail

declare -r MY_D="$(readlink -f "$(dirname "${BASH_SOURCE}")")"
declare -r ROOT_D="$(readlink -f "${MY_D}/..")"
declare -r OUT_D="${OUT_D:-${ROOT_D}/config}"
declare -r ITERATIONS="${ITERATIONS:-50}"
declare -r STREAM_MODES="${STREAM_MODES:-txrx}"
declare -r DATA_SIZES="${DATA_SIZES:-10mb:10485760}"
declare -r BLOCK_SIZES="${BLOCK_SIZES:-256k:256K}"
declare -r DATA_SOURCES="${DATA_SOURCES:-zero}"
declare -r USE_TSH_PROXY="${USE_TSH_PROXY:-true}"
declare -r NAMESPACE="${NAMESPACE:-teleport-performance}"
declare -r POD="${POD:-tperf-target}"
declare -r IMAGE="${IMAGE:-busybox:latest}"
declare -r MAX_READY_WAIT="${MAX_READY_WAIT:-5m}"

usage() {
  printf >&2 "Usage: %s <cluster-config file>\n" "$(basename "${BASH_SOURCE}")"
  exit 1
}

die() {
  printf >&2 "ERROR: %s\n" "${*}"
  exit 1
}

[[ "${#}" -eq 1 ]] || usage
declare -r CLUSTER_FILE="${1}"
[[ -r "${CLUSTER_FILE}" ]] || die "Cluster config '${CLUSTER_FILE}' not found"

declare -r YQ_TELEPORT='.tbot.clusterName'
declare -r YQ_KUBE='.tbot.services[0].selectors[0].name'
TP_CLUSTER="$(yq -e <"${CLUSTER_FILE}" "${YQ_TELEPORT}")" \
  || die "Failed to read '${YQ_TELEPORT}' from '${CLUSTER_FILE}'"
K8S_CLUSTER="$(yq -e <"${CLUSTER_FILE}" "${YQ_KUBE}")" \
  || die "Failed to read '${YQ_KUBE}' from '${CLUSTER_FILE}'"
declare -r TP_CLUSTER
declare -r K8S_CLUSTER
declare -r CLUSTER_NAME="$(basename "${CLUSTER_FILE}" .yaml)"
declare -r CONTEXT_NO_TP="${CONTEXT_NO_TP:-${K8S_CLUSTER}}"
declare -r CONTEXT_TP="${CONTEXT_TP:-${TP_CLUSTER}-${K8S_CLUSTER}}"
declare -r TP_CONTEXT_PREFIX="${TP_CLUSTER}-"
[[ "${CONTEXT_TP}" == "${TP_CONTEXT_PREFIX}"* ]] \
  || die "CONTEXT_TP '${CONTEXT_TP}' must start with '${TP_CONTEXT_PREFIX}'"

mkdir -p "${OUT_D}"

block_bytes() {
  local size
  size="$(printf "%s" "${1}" | tr '[:lower:]' '[:upper:]')"
  local re='^([0-9]+)([KMG])$'
  local n unit
  [[ "${size}" =~ ${re} ]] || die "Unsupported block size '${1}'"
  n="${BASH_REMATCH[1]}"
  unit="${BASH_REMATCH[2]}"
  case "${unit}" in
    K) printf "%d\n" "$(( n * 1024 ))" ;;
    M) printf "%d\n" "$(( n * 1024 * 1024 ))" ;;
    G) printf "%d\n" "$(( n * 1024 * 1024 * 1024 ))" ;;
  esac
}

count_for() {
  local total_bytes="${1}"
  local block_size="${2}"
  local bytes_per_block
  bytes_per_block="$(block_bytes "${block_size}")"

  if (( total_bytes < bytes_per_block )); then
    return 1
  fi

  if (( total_bytes % bytes_per_block != 0 )); then
    return 1
  fi

  printf "%d\n" "$(( total_bytes / bytes_per_block ))"
}

quote_shell() {
  printf '%q' "${1}"
}

output_file() {
  local iterations="${1}"
  shift
  local components=("$@")
  components+=("x${iterations}")
  local IFS='-'
  printf "%s/local.%s.%s\n" "${OUT_D}" "${CLUSTER_NAME}" "${components[*]}"
}

write_config() {
  local out="${1}"
  local cmd="${2}"
  local tx_count="${3}"
  local tx_block_size="${4}"
  local tx_infile="${5}"

  {
    printf '# Generated by %s from %s\n' \
      "$(basename "${BASH_SOURCE}")" \
      "${CLUSTER_FILE}"
    printf 'TP_CLUSTER=%s\n' "$(quote_shell "${TP_CLUSTER}")"
    printf 'CONTEXT_NO_TP=%s\n' "$(quote_shell "${CONTEXT_NO_TP}")"
    printf 'CONTEXT_TP=%s\n' "$(quote_shell "${CONTEXT_TP}")"
    printf 'USE_TSH_PROXY=%s\n' "$(quote_shell "${USE_TSH_PROXY}")"
    printf 'NAMESPACE=%s\n' "$(quote_shell "${NAMESPACE}")"
    printf 'POD=%s\n' "$(quote_shell "${POD}")"
    printf 'IMAGE=%s\n' "$(quote_shell "${IMAGE}")"
    printf 'MAX_READY_WAIT=%s\n' "$(quote_shell "${MAX_READY_WAIT}")"
    printf 'ITERATIONS=%s\n' "$(quote_shell "${ITERATIONS}")"
    printf 'CMD=%s\n' "$(quote_shell "${cmd}")"
    printf 'TX_COUNT=%s\n' "$(quote_shell "${tx_count}")"
    printf 'TX_BLOCK_SIZE=%s\n' "$(quote_shell "${tx_block_size}")"
    printf 'TX_INFILE=%s\n' "$(quote_shell "${tx_infile}")"
  } > "${out}"
  printf '%s\n' "${out}"
}

write_config \
  "$(output_file "${ITERATIONS}" ls)" \
  "" \
  "0" \
  "0" \
  "/dev/zero"

write_config \
  "$(output_file "${ITERATIONS}" exec latency)" \
  "echo hello" \
  "0" \
  "0" \
  "/dev/zero"

for source in ${DATA_SOURCES}; do
  infile="/dev/${source}"
  for size_spec in ${DATA_SIZES}; do
    IFS=: read -r size_name total_bytes <<< "${size_spec}"
    [[ -n "${size_name}" && -n "${total_bytes}" ]] \
      || die "Invalid data size spec '${size_spec}'"
    for block_spec in ${BLOCK_SIZES}; do
      IFS=: read -r block_name block_size <<< "${block_spec}"
      [[ -n "${block_name}" && -n "${block_size}" ]] \
        || die "Invalid block size spec '${block_spec}'"
      count="$(count_for "${total_bytes}" "${block_size}")" || continue

      for stream_mode in ${STREAM_MODES}; do
        case "${stream_mode}" in
          tx)
            write_config \
              "$(output_file "${ITERATIONS}" tx "${source}" "${size_name}" "${block_name}")" \
              "true" \
              "${count}" \
              "${block_size}" \
              "${infile}"
            ;;
          rx)
            write_config \
              "$(output_file "${ITERATIONS}" rx "${source}" "${size_name}" "${block_name}")" \
              "dd if=${infile} bs=${block_size} count=${count} status=none" \
              "0" \
              "0" \
              "${infile}"
            ;;
          txrx)
            write_config \
              "$(output_file "${ITERATIONS}" txrx "${source}" "${size_name}" "${block_name}")" \
              "cat" \
              "${count}" \
              "${block_size}" \
              "${infile}"
            ;;
          *)
            die "Unsupported STREAM_MODES entry '${stream_mode}'"
            ;;
        esac
      done
    done
  done
done
