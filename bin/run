#!/bin/bash
set -euo pipefail
declare -r MY_D="$(readlink -f "$(dirname "${BASH_SOURCE}")")"
. "${MY_D}/include.sh"

declare CMD="upgrade --install"

DEBUG_FLAG=""
OVERWRITE="${OVERWRITE:-}"
if [[ -n "${DEBUG}" ]]; then
  CMD="template"
  DEBUG_FLAG="--debug"
fi

if ! force; then 
  if complete; then
    msg "Job run and done, fetching results..."
    "${ROOT_D}/bin/get-results"
    exit 0
  fi
  if running; then
    msg "Job still running"
    run_kubectl get "job/${K8S_JOB_NAME}"
    run_kubectl get pods -l "app.kubernetes.io/name=tperf,app.kubernetes.io/component=test-runner,app.kubernetes.io/instance=${RELEASE}}"
    exit 0
  fi
fi

# export because we use them both here and in apply.sh
export TOKEN
export DEBUG
export OVERWRITE
BOT="${NAME}-bot" \
ROLE="${NAME}" \
K8S_GROUP="${GROUP}" \
K8S_NAMESPACE="${NAMESPACE}" \
K8S_SA="${RELEASE}" \
"${ROOT_D}/teleport/apply.sh" "${CONTEXT}" \
|| die "Failed to apply teleport objects"

msg "Deleting old jobs"
run_kubectl delete "job/${K8S_JOB_NAME}" --ignore-not-found \
  || die "Failed to clean up old jobs"

msg "Ensuring helm deps"
helm dependency build >&2 . \
  || die "Failed to build deps"

msg "Installing chart"
(set -x; helm ${CMD} \
  "${RELEASE}" "${ROOT_D}" \
  --kube-context "${CONTEXT}" \
  --namespace "${NAMESPACE}" \
  --set group="${GROUP}" \
  --set tbot.token="${TOKEN}" \
  -f "${JOB_YAML}" \
  -f "${CLUSTER_YAML}" \
  ${DEBUG_FLAG}
  ) \
  || die "Failed to helm"
