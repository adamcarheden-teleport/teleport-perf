#!/bin/bash
set -euo pipefail
declare -r MY_D="$(readlink -f "$(dirname "${BASH_SOURCE}")")"
. "${MY_D}/include.sh"

declare CMD="upgrade --install"
declare -r DEBUG_RUNNER_POD="${DEBUG_RUNNER_POD:-}"

DEBUG_FLAGS=""
OVERWRITE="${OVERWRITE:-}"
if debug; then
  CMD="template"
  DEBUG_FLAGS="--debug"
fi
[[ -n "${DEBUG_RUNNER_POD}" && "$(echo "${DEBUG_RUNNER_POD}" | tr 'a-z' 'A-Z')" != "FALSE" ]] \
  && DEBUG_FLAGS="${DEBUG_FLAGS} --set debug_runner_pod=true"

if ! force; then 
  if have_saved_results; then
    msg "Saved results found, printing report..."
    report_saved_results
    exit "${EXIT_COMPLETE}"
  fi
  debug && msg "checking if complete..."
  if complete; then
    msg "Job run and done, fetching results..."
    "${ROOT_D}/bin/get-results" "${@}"
    exit "${EXIT_COMPLETE}"
  fi
  echo >&2 "### Ignore the error below if no jobs are found"
  (DEBUG=t run_kubectl get "job/${K8S_JOB_NAME}" || true)
  echo >&2 "### Ignore the error below if no pods are found"
  (DEBUG=t run_kubectl get pods -l "${K8S_RUNNER_LABELS}" || true)
  debug && msg "not complete, checking if running..."
  if running; then
    msg "Job still running"
    exit "${EXIT_RUNNING}"
  fi
  debug && msg "not running or complete, checking if failed..."
  if failed; then
    msg "Job failed. Run with envvar FORCE=true to run it again. Saving status..."
    "${ROOT_D}/bin/get-results" "${@}"
    exit "${EXIT_FAILED}"
  fi
else
  debug && msg "Force enabled, skipped checking for existing runs"
fi

msg "Ensuring shared service account"
cat <<EOF | run_kubectl apply -f - \
  || die "Failed to apply service account '${SERVICE_ACCOUNT}'"
apiVersion: v1
kind: ServiceAccount
metadata:
  name: ${SERVICE_ACCOUNT}
  namespace: ${NAMESPACE}
EOF

# export because we use them both here and in apply.sh
export TOKEN
export DEBUG
export OVERWRITE

# Used in the helm values
ROLE="${CLUSTER}-${PROJECT_NAME}"

BOT="${CLUSTER}-${PROJECT_NAME}-bot" \
ROLE="${CLUSTER}-${PROJECT_NAME}" \
K8S_GROUP="${GROUP}" \
K8S_NAMESPACE="${NAMESPACE}" \
K8S_SA="${SERVICE_ACCOUNT}" \
"${ROOT_D}/teleport/apply.sh" "${CONTEXT}" \
|| die "Failed to apply teleport objects"

if [[ -e "${RESULTS_TSV}" || -e "${STATUS_YAML}" ]]; then
  msg "Archiving old results"
  arc_ts="$(date +%s)"
  if [[ -e "${RESULTS_TSV}" ]]; then
    (set -x; mv "${RESULTS_TSV}" "${RESULTS_TSV}.archived_at_${arc_ts}") \
      || die "Failed to archive old results"
  fi
  if [[ -e "${STATUS_YAML}" ]]; then
    (set -x; mv "${STATUS_YAML}" "${STATUS_YAML}.archived_at_${arc_ts}") \
      || die "Failed to archive old results"
  fi
fi

if force; then
  if started; then
    # FORCE explicitly opts into deleting any existing Job before re-running.
    msg "Deleting old jobs"
    run_kubectl delete "job/${K8S_JOB_NAME}" --ignore-not-found \
      || die "Failed to clean up old jobs"
  fi
elif started; then
  msg "Job exists but is neither complete, running, nor failed. Refusing to delete without FORCE=true."
  exit "${EXIT_UNKNOWN}"
fi

msg "Ensuring helm deps"
helm dependency build >&2 . \
  || die "Failed to build deps"

# Order of the -f and --set below matters. We force things that have to be a
# certain way at the end so they take precedence.
msg "Installing chart"
(set -x; helm ${CMD} \
  "${RELEASE}" "${ROOT_D}" \
  --kube-context "${CONTEXT}" \
  --namespace "${NAMESPACE}" \
  --set app_name="${PROJECT_NAME}" \
  --set group="${GROUP}" \
  --set tbot.serviceAccount.create=false \
  --set tbot.serviceAccount.name="${SERVICE_ACCOUNT}" \
  --set tbot.token="${TOKEN}" \
  -f "${JOB_YAML}" \
  -f "${CLUSTER_YAML}" \
  --set tbot.services[0].type="kubernetes/v2" \
  --set tbot.services[0].destination.name="${RELEASE}-tbot-k8s" \
  --set tbot.services[0].destination.type="kubernetes_secret" \
  --set tbot.services[0].destination.namespace="${NAMESPACE}" \
  --set tbot.services[1].type="identity" \
  --set tbot.services[1].destination.name="${RELEASE}-tbot-id" \
  --set tbot.services[1].destination.type="kubernetes_secret" \
  --set tbot.services[1].destination.namespace="${NAMESPACE}" \
  --set tbot.services[1].roles[0]="${ROLE}" \
  --set tbot.services[1].allow_reissue="true" \
  ${DEBUG_FLAGS} \
  ) \
  || die "Failed to helm"

exit "${EXIT_STARTED}"
